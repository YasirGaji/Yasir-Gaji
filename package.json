    "@sanity/vision": "5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-sanity": "12",
    "next-view-transitions": "^0.3.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "5",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "styled-components": "6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
